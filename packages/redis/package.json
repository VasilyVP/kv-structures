{
  "name": "@kv-structures/redis",
  "version": "4.0.0",
  "description": "JavaScript data structures for Redis",
  "keywords": [
    "Redis",
    "data structures",
    "Map",
    "Set"
  ],
  "homepage": "https://github.com/VasilyVP/kv-structures/tree/main/packages/redis",
  "bugs": {
    "url": "https://github.com/VasilyVP/kv-structures/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VasilyVP/kv-structures/tree/main/packages/redis"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "license": "ISC",
  "author": "VasilyVP",
  "type": "module",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "pkgroll --target=es2024 --target=node22 --clean-dist --minify",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@redis/client": "^6.0.1",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^26.0.1",
    "json-bigint": "^1.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "^4.1.9",
    "pkgroll": "^2.27.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}